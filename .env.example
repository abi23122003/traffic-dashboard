# Required API keys
TOMTOM_KEY=your_tomtom_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# App security and auth
SECRET_KEY=change-this-secret-key-in-production
SECURE_COOKIES=false
DEFAULT_POLICE_USERNAME=officer_raj
DEFAULT_POLICE_PASSWORD=Police123
DEFAULT_POLICE_EMAIL=officer_raj@trafficdashboard.com

# Database
DB_TYPE=sqlite
DB_PATH=traffic_analysis.db
MODEL_PATH=rf_model.pkl
POSTGRES_USER=traffic_user
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=traffic_dashboard

# Files and exports
ROUTES_CSV=routes.csv
OUTPUT_CSV=traffic_results.csv
VIS_DIR=visuals

# Logging and realtime
LOG_LEVEL=INFO
SOCKETIO_REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL=10

# Email notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@trafficdashboard.com

# Firebase push notifications
FIREBASE_CREDENTIALS_JSON=

# Power BI push (optional)
POWERBI_PUSH_ENABLED=false
POWERBI_DATASET_ID=
POWERBI_TABLE_NAME=
POWERBI_BEARER_TOKEN=

# Azure MSAL (optional)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
